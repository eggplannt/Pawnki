# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's API URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (safe to use client-side)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Secret key (server-side / admin operations only — never expose to clients)
SUPABASE_SECRET_KEY=sb_secret_your-key-here

# ─── Supabase local dev (supabase/.env) ───────────────────────────────────────
# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
# Add <supabase-url>/auth/v1/callback to your OAuth app's authorized redirect URIs
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Site URL used by Supabase auth redirects
SITE_URL=http://localhost:3000

# OAuth redirect URI (must match what's registered in Google Cloud Console)
OATH_REDIRECT_URI=https://your-project-ref.supabase.co/auth/v1/callback

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Found in: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ─── Web (apps/web/.env.local) ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Set to "true" when running against a self-hosted Supabase instance
VITE_SELF_HOSTED=false

# Stripe publishable key and price IDs
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_MONTHLY=price_...
VITE_STRIPE_PRICE_ANNUAL=price_...

# Google AdSense — ads.google.com → Account → Publisher ID
VITE_ADSENSE_CLIENT_ID=ca-pub-your-publisher-id
VITE_ADSENSE_SLOT_PRESESSION=your-ad-slot-id

# ─── Expo (apps/expo/.env.local) ──────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Google AdMob interstitial ad unit ID
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-your-id/your-unit-id
