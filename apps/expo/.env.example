# apps/expo/.env.local — copy this file to .env.local and fill in your values.
# These override the committed apps/expo/.env for local dev or custom deployments.

# Supabase — get from `supabase status` (local) or Project Settings → API (cloud)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Google AdMob interstitial ad unit ID
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-your-id/your-unit-id
