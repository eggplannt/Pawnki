{
  "expo": {
    "name": "Pawnki",
    "slug": "pawnki",
    "version": "0.1.0",
    "scheme": "pawnki",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pawnki.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f1117"
      },
      "package": "com.pawnki.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "684e9097-8b63-4d29-9333-6ee14498d664"
      }
    },
    "owner": "abdulsalamo"
  }
}
