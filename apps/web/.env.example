# apps/web/.env.local — copy this file to .env.local and fill in your values.
# These override the committed apps/web/.env for local dev or custom deployments.

# Supabase — get from `supabase status` (local) or Project Settings → API (cloud)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Stripe — dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_MONTHLY=price_...
VITE_STRIPE_PRICE_ANNUAL=price_...

# Google AdSense — ads.google.com → Account → Publisher ID
VITE_ADSENSE_CLIENT_ID=ca-pub-your-publisher-id
VITE_ADSENSE_SLOT_PRESESSION=your-ad-slot-id
