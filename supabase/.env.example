# Google OAuth credentials for local Supabase dev
# Get these from: console.cloud.google.com → APIs & Services → Credentials
# Add <supabase-url>/auth/v1/callback to your OAuth app's authorized redirect URIs
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Site URL used by Supabase auth redirects
# Use localhost, a Tailscale IP (http://100.x.x.x:3000), or your production domain
SITE_URL=http://localhost:3000
